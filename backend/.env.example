# ── Zero Trace Cyber Legacy — Environment Variables ──
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

PORT=5000

# MongoDB Atlas connection string
# Get from: mongodb.com/atlas → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/zerotrace?retryWrites=true&w=majority

# JWT secret — make this long and random
JWT_SECRET=zt_secret_change_this_to_something_long_and_random_2024

# Frontend URL (for CORS) — change after deploy
CLIENT_URL=http://localhost:5500
